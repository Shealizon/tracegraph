{
  "name": "paper-graph",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive relation graph viewer for papers and structured knowledge graphs",
  "scripts": {
    "extract": "node scripts/extract.mjs",
    "dev": "vite",
    "build": "node ./node_modules/vite/bin/vite.js build --minify false",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "katex": "^0.16.11"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
