PORT=8787
HOST=0.0.0.0
PAPER_GRAPH_DATA=./server-data
JSON_LIMIT=32mb
# Set to 0 when the host does not provide the `codex` CLI.
CODEX_ENABLED=1
# Optional absolute executable/entrypoint override for non-standard installations.
# CODEX_BIN=/usr/local/bin/codex
ALLOW_REGISTRATION=1
# Optional secure bootstrap; set both before the first server start.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=replace-with-a-long-random-password
