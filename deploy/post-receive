#!/usr/bin/env bash
# Deploy Tracegraph after updates to the main branch.
set -euo pipefail

DEPLOY_BRANCH="refs/heads/main"
WORK_TREE="/root/Desktop/tracegraph"
APP_DIR="/opt/tracegraph"
PUBLISH_DIR="/var/www/tracegraph"
LOG_FILE="/tmp/tracegraph-deploy.log"

while read -r oldrev newrev refname; do
  if [ "$refname" != "$DEPLOY_BRANCH" ]; then
    echo "Skipping $refname; deploy branch is $DEPLOY_BRANCH"
    continue
  fi

  {
    echo "=== tracegraph deploy $(date -Is) ==="
    echo "ref: $refname"
    echo "old: $oldrev"
    echo "new: $newrev"

    if ! id tracegraph >/dev/null 2>&1; then
      useradd --system --home-dir /var/lib/tracegraph --create-home --shell /sbin/nologin tracegraph
    fi
    mkdir -p "$WORK_TREE" "$APP_DIR" "$PUBLISH_DIR"
    install -d -o tracegraph -g tracegraph -m 0750 /var/lib/tracegraph /var/lib/tracegraph/data
    git --work-tree="$WORK_TREE" --git-dir=/root/repos/tracegraph.git checkout -f main

    cd "$WORK_TREE"
    npm ci
    npm audit
    npm run test:run
    npm run build

    rm -rf "${APP_DIR:?}"/*
    tar \
      --exclude=./.git \
      --exclude=./node_modules \
      --exclude=./server-data \
      --exclude=./output \
      -cf - . | tar -C "$APP_DIR" -xf -
    cd "$APP_DIR"
    npm ci --omit=dev

    rm -rf "${PUBLISH_DIR:?}"/*
    cp -a dist/. "$PUBLISH_DIR"/
    chown -R tracegraph:tracegraph "$APP_DIR" /var/lib/tracegraph

    install -m 0644 deploy/tracegraph.service /etc/systemd/system/tracegraph.service
    install -m 0644 deploy/nginx-tracegraph.conf /etc/nginx/conf.d/tracegraph.conf
    systemctl daemon-reload
    systemctl enable tracegraph.service
    systemctl restart tracegraph.service

    nginx -t
    systemctl reload nginx
    echo "Deploy complete."
  } 2>&1 | tee "$LOG_FILE"
done
